{
  "name": "tkajui",
  "version": "0.1.0",
  "description": "TkajUI — generic React component library. Cool neutral palette + blue accent, octagonal silhouettes via CSS clip-path, no Tailwind dependency. Ships JSDoc-typed components, a single CSS file with custom properties + utility classes, and a token export for inline styling.",
  "type": "module",
  "license": "MIT",
  "sideEffects": ["*.css"],
  "files": [
    "dist",
    "*.js",
    "*.jsx",
    "tkajui.css",
    "enums.js",
    "README.md",
    "LICENSE"
  ],
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".":              { "source": "./index.js",   "types": "./dist/index.d.ts",  "import": "./dist/index.js",  "require": "./dist/index.cjs" },
    "./tokens":       { "source": "./tokens.js",  "types": "./dist/tokens.d.ts", "import": "./dist/tokens.js", "require": "./dist/tokens.cjs" },
    "./enums":        { "source": "./enums.js",   "types": "./dist/enums.d.ts",  "import": "./dist/enums.js",  "require": "./dist/enums.cjs" },
    "./styles":       "./tkajui.css",
    "./tkajui.css":   "./tkajui.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build":          "tsup",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "react":     ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@tkaj/donjon-shared": "*"
  },
  "keywords": ["react", "ui-library", "design-system", "octagon", "clip-path", "components"],
  "repository": {
    "type": "git",
    "url":  "https://github.com/Tkaj39/Style-guite-donjon-fall.git",
    "directory": "src/lib/tkajui"
  }
}
