{
  "name": "donjon-fall-ui",
  "version": "0.1.0",
  "description": "donjon-fall-ui — game UI component library built on top of TkajUI. Warm medieval gold palette, ornament SVGs (RohOrnament, SideOrnament, HexOrnament, …), HUD layout, gameplay primitives (Dialogue, ChoicePanel, RewardPopup, AchievementToast, LevelUp), and a full suite of Donjon* variants that extend the TkajUI counterparts with gold borders and octagonal ornaments.",
  "type": "module",
  "license": "MIT",
  "sideEffects": ["*.css"],
  "files": [
    "dist",
    "*.js",
    "*.jsx",
    "donjon.css",
    "enums.js",
    "README.md",
    "LICENSE"
  ],
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".":              { "source": "./index.js",        "types": "./dist/index.d.ts",        "import": "./dist/index.js",        "require": "./dist/index.cjs" },
    "./tokens":       { "source": "./tokens.js",       "types": "./dist/tokens.d.ts",       "import": "./dist/tokens.js",       "require": "./dist/tokens.cjs" },
    "./enums":        { "source": "./enums.js",        "types": "./dist/enums.d.ts",        "import": "./dist/enums.js",        "require": "./dist/enums.cjs" },
    "./playerColors": { "source": "./playerColors.js", "types": "./dist/playerColors.d.ts", "import": "./dist/playerColors.js", "require": "./dist/playerColors.cjs" },
    "./styles":       "./donjon.css",
    "./donjon.css":   "./donjon.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build":          "tsup",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "react":     ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@tkaj/donjon-shared": "*",
    "tkajui":              "*"
  },
  "keywords": ["react", "ui-library", "game-ui", "design-system", "octagon", "medieval", "rpg"],
  "repository": {
    "type": "git",
    "url":  "https://github.com/Tkaj39/Style-guite-donjon-fall.git",
    "directory": "src/lib/donjon"
  }
}
